BOT_TOKEN='Your-bot-token'
PAYMENT_TOKEN='39054xxxx:LIVE:45xxx' # payment token from @BotFather
ADMINS=1234567890
XUI_API_URL=http://ip-or-domain:2053 # panel url
XUI_BASE_PATH=/panel
# API-токен из панели 3x-ui: Settings → API Keys → Generate API Key
XUI_API_TOKEN=
XUI_SUB_PORT=2096
SUBSCRIPTION_URL_BASE=ip-or-domain
SUB_BASE_PATH=/sub
XUI_VERIFY_SSL=False
# ──────────────────────────────────────────────────────────────
# Система тарифов: ID инбаундов через запятую (из панели 3x-ui)
# Протокол определяется автоматически из панели
# ──────────────────────────────────────────────────────────────
# standard-клиент (безлимит) — для всех тарифов
STANDARD_INBOUNDS=1
# wl-клиент (с лимитом) — только для premium, поверх standard
# Оставьте пустым если premium-тир не нужен
PREMIUM_INBOUNDS=3
# Лимит трафика для wl-клиента в ГБ (0 = безлимит)
PREMIUM_TRAFFIC_LIMIT_GB=100
# Лимит трафика для standard-клиента в ГБ (0 = безлимит)
STANDARD_TRAFFIC_LIMIT_GB=0
# Лимит одновременных IP для standard-клиента (0 = безлимит)
STANDARD_IP_LIMIT=0
# Лимит одновременных IP для premium/wl-клиента (0 = безлимит)
PREMIUM_IP_LIMIT=0
PREMIUM_PRICE_MULTIPLIER=1.5
TRIAL_DAYS=3
TRIAL_TIER=standard

# ──────────────────────────────────────────────────────────────
# Tribute (опционально — второй способ оплаты через tribute.tg)
# Как получить API-ключ:
#   Tribute Dashboard → ⋮ → Settings → API Keys → Generate API Key
# Webhook URL прописать там же:
#   https://your-domain.com:8081/tribute/webhook
# ──────────────────────────────────────────────────────────────
TRIBUTE_API_KEY=
TRIBUTE_WEBHOOK_PORT=8081
TRIBUTE_BASIC_PLAN_NAME=Standart
TRIBUTE_PREMIUM_PLAN_NAME=Premium
# Ссылки на страницы оплаты (Tribute Dashboard → подписка → «Поделиться»)
# Если не заданы — кнопки Tribute не появляются в боте
TRIBUTE_BASIC_URL=
TRIBUTE_PREMIUM_URL=
# Цифровые товары: JSON-список объектов {name, tier, hours}
# tier: standard | premium  |  hours: срок подписки в часах
# Пример: [{"name":"VPN 1 Month","tier":"standard","hours":720},{"name":"VPN Premium","tier":"premium","hours":720}]
TRIBUTE_DIGITAL_PRODUCTS=[]

