BOT_TOKEN='Your-bot-token'
PAYMENT_TOKEN='39054xxxx:LIVE:45xxx' # payment token from @BotFather
ADMINS=1234567890
XUI_API_URL=http://ip-or-domain:2053 # panel url
XUI_HOST=ip-or-domain
XUI_BASE_PATH=/panel
XUI_SERVER_NAME=ip-or-domain
XUI_USERNAME=admin
XUI_PASSWORD=admin

# ──────────────────────────────────────────────────────────────
# Старые поля (backwards-compat, fallback если BASIC_INBOUNDS не задан)
# ──────────────────────────────────────────────────────────────
INBOUND_ID=1
REALITY_PUBLIC_KEY=pubkey_reality
REALITY_FINGERPRINT=chrome
REALITY_SNI=teamdocs.su
REALITY_SHORT_ID=short_id_reality
REALITY_SPIDER_X=/

# ──────────────────────────────────────────────────────────────
# Новая система тарифов: "id:protocol,id:protocol"
# Протоколы: reality | xhttp
# ──────────────────────────────────────────────────────────────
BASIC_INBOUNDS=1:reality
PREMIUM_INBOUNDS=1:reality,3:xhttp
PREMIUM_PRICE_MULTIPLIER=1.5

# ──────────────────────────────────────────────────────────────
# Параметры каждого инбаунда: INBOUND_{ID}_*
# ──────────────────────────────────────────────────────────────

# Reality инбаунд id=1
INBOUND_1_PUBLIC_KEY=pubkey_reality
INBOUND_1_FINGERPRINT=chrome
INBOUND_1_SNI=teamdocs.su
INBOUND_1_SHORT_ID=short_id_reality
INBOUND_1_SPIDER_X=/

# xhttp инбаунд id=3
INBOUND_3_SNI=your-domain.com
INBOUND_3_PATH=/
INBOUND_3_SECURITY=tls
INBOUND_3_HOST=

# ──────────────────────────────────────────────────────────────
# Временные профили (30 минут)
# TEMP_INBOUND_CONFIGS=2:reality,4:xhttp
# ──────────────────────────────────────────────────────────────
TEMP_INBOUND_CONFIGS=2:reality
INBOUND_2_PUBLIC_KEY=pubkey_reality_temp
INBOUND_2_FINGERPRINT=chrome
INBOUND_2_SNI=teamdocs.su
INBOUND_2_SHORT_ID=short_id_reality_temp
INBOUND_2_SPIDER_X=/

# Параметры xhttp тест-инбаунда id=4 (раскомментировать если нужен)
# INBOUND_4_SNI=your-domain.com
# INBOUND_4_PATH=/
# INBOUND_4_SECURITY=tls

# Старые поля (backwards-compat)
TEMP_INBOUND_ID=2
TEMP_REALITY_PUBLIC_KEY=pubkey_reality_temp
TEMP_REALITY_FINGERPRINT=chrome
TEMP_REALITY_SNI=teamdocs.su
TEMP_REALITY_SHORT_ID=short_id_reality_temp
TEMP_REALITY_SPIDER_X=/
TEMP_WEB_SERVER_PORT=8080
TEMP_SSL_CERT_PATH=/path/to/fullchain.pem
TEMP_SSL_KEY_PATH=/path/to/privkey.pem
